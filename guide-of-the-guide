//
//  GPT - EFI PARTITION FOR MEEEEEE :333
//  
//  SDA1    /efi    vfat      type = 1
//  SDA2    -       swap      type = 19
//  SDA3    /       xfs       type = 23
//  

// Commands to do after partitioning

mkfs.vfat -F 32 /dev/sda1
mkfs.xfs /dev/sda3
mkswap /dev/sda2
swapon /dev/sda2
mkdir --parents /mnt/gentoo
mount /dev/sda3 /mnt/gentoo


// Stage tarball stuff

date [monthdayhourminuteyear]
cd /mnt/gentoo
wget [gentoo-stage-file]
tar xpvf stage3-*.tar.xz --xattrs-include='*.*' --numeric-owner


// Add the custom make.conf at mont141414.github.io


// Chrooting (can be redone maybe)

cp --dereference /etc/resolv.conf /mnt/gentoo/etc/
mount --types proc /proc /mnt/gentoo/proc 
mount --rbind /sys /mnt/gentoo/sys 
mount --make-rslave /mnt/gentoo/sys 
mount --rbind /dev /mnt/gentoo/dev 
mount --make-rslave /mnt/gentoo/dev 
mount --bind /run /mnt/gentoo/run 
mount --make-slave /mnt/gentoo/run 
test -L /dev/shm && rm /dev/shm && mkdir /dev/shm 
mount --types tmpfs --options nosuid,nodev,noexec shm /dev/shm 
chmod 1777 /dev/shm /run/shm
chroot /mnt/gentoo /bin/bash 
source /etc/profile 
export PS1="(chroot) ${PS1}"


// Prepare bootloader

mkdir /efi 
mount /dev/sda1 /efi 


// Configuring portage

mkdir --parents /etc/portage/repos.conf
cp /usr/share/portage/config/repos.conf /etc/portage/repos.conf/gentoo.conf
emerge-webrsync


// Profile thing not needed, but good to check

eselect profile list


// Maybe install the package binary host thing later, just add the following to /etc/portage/binrepos.conf/gentoo.conf

[binhost]
priority = 9999
sync-uri = https://gentoo.c3sl.ufpr.br/releases/amd64/binpackages/17.1/x86-64/


// Now update @world set!

emerge --ask --verbose --update --deep --newuse @world


// Timezone moment

echo "Brazil/East" > /etc/timezone


// Modify the locale thing, just add the US one I guess..

nano /etc/locale.gen
locale-gen
eselect locale list
eselect locale set [number]


// Reload environment

env-update && source /etc/profile && export PS1="(chroot) ${PS1}"


// Kernel stuff (too lazy to make custom one)

emerge --ask sys-kernel/installkernel
emerge --ask sys-kernel/linux-firmware
emerge --ask sys-kernel/gentoo-kernel-bin


// Fstab stuff (add this to /etc/fstab)

/dev/sda1	/efi	vfat	defaults	0 2
/dev/sda2	none	swap	sw	0 0
/dev/sda3	/	xfs	defaults,noatime	0 1
/dev/cdrom	/mnt/cdrom	auto	noauto,user	0 0


// Network stuff

echo mont > /etc/hostname
emerge --ask net-misc/dhcpcd net-wireless/iw net-wireless/wpa_supplicant
rc-update add dhcpcd default 
rc-service dhcpcd start 


// Add host to this...

nano /etc/hosts


// Root password

passwd


// Set keymap to br-abnt2 (keyboard layout I use)

nano /etc/conf.d/keymaps


// Clock sync + xfsprogs

emerge --ask net-misc/chrony
rc-update add chronyd default
emerge --ask sys-fs/xfsprogs


// EFI Boot stuff

emerge --ask sys-boot/efibootmgr
mkdir -p /efi/efi/gentoo
cp /boot/vmlinuz-*-dist /efi/efi/gentoo/bzImage.efi 
efibootmgr --create --disk /dev/sda --part 1 --label "gentoo" --loader "\efi\gentoo\bzImage.efi"


// User and cleaning

rm /stage3-*.tar.*
useradd -m -G users,wheel,audio,cdrom,portage,usb,video -s /bin/bash mont
passwd mont


// Doas

emerge --ask app-admin/doas
echo "permit mont as root" > /etc/doas.conf 

================================================================================================

// Neovim

emerge --ask app-editors/neovim
eselect editor set /usr/bin/nvim
emerge --ask --depclean app-editors/nano


// Curl

emerge --ask net-misc/curl

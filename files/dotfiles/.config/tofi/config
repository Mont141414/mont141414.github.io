# Fonts

font = "Monospace"
font-size = 16
hint-font = false


# Text theming

text-color = #F1F2E1
prompt-color = #E6BC0D
prompt-background = #00000000
prompt-background-padding = 0
prompt-background-corner-radius = 0
placeholder-color = #EDF37B
placeholder-background = #00000000
placeholder-background-padding = 0
placeholder-background-corner-radius = 0
input-color = #F1F2E1
input-background = #00000000
input-background-padding = 0
input-background-corner-radius = 0
default-result-color = #F1F2E1
default-result-background = #00000000
default-result-background-padding = 0
default-result-background-corner-radius = 0
alternate-result-color = #F1F2E1
alternate-result-background = #00000000
alternate-result-background-padding = 0
alternate-result-background-corner-radius = 0
selection-color = #E6BC0D
selection-background = #00000000
selection-background-padding = 0
selection-background-corner-radius = 0
selection-match-color = #00000000


# Text cursor theme

text-cursor-style = underscore
text-cursor-color = #EDF37B
text-cursor-background = #000000
text-cursor-corner-radius = 0


# Text layout

prompt-text = "  🭬"
prompt-padding = 0
placeholder-text = "Search..."
num-results = 0
result-spacing = 0
horizontal = false
min-input-width = 0


# Window theming

width = 720
height = 720
background-color = #010027DD
outline-width = 0
outline-color = #2F057D
border-width = 2
border-color = #F1F2E1
corner-radius = 0
padding-top = 8
padding-bottom = 8
padding-left = 8
padding-right = 8
clip-to-padding = true
scale = true


# Window positioning

output = ""
anchor = center
exclusive-zone = -1
margin-top = 0
margin-bottom = 0
margin-left = 0
margin-right = 0


# Behaviour

hide-cursor = false
text-cursor = true
history = false
matching-algorithm = normal
require-match = true
auto-accept-single = false
hide-input = false
hidden-character = "*"
physical-keybindings = true
print-index = false
drun-launch = false
terminal = kitty
late-keyboard-init = false
multi-instance = false
ascii-input = false

BACKLASH_E=$'\x1b'

DARKEST_BLUE_FG="${BACKLASH_E}[38;2;1;0;39m"
DARKEST_BLUE_BG="${BACKLASH_E}[48;2;1;0;39m"
DARK_BLUE_FG="${BACKLASH_E}[38;2;47;5;125m"
DARK_BLUE_BG="${BACKLASH_E}[48;2;47;5;125m"
LIGHT_BLUE_FG="${BACKLASH_E}[38;2;13;27;230m"
LIGHT_BLUE_BG="${BACKLASH_E}[48;2;13;27;230m"
LIGHTEST_BLUE_FG="${BACKLASH_E}[38;2;123;154;243m"
LIGHTEST_BLUE_BG="${BACKLASH_E}[48;2;123;154;243m"

DARKEST_YELLOW_FG="${BACKLASH_E}[38;2;160;107;31m"
DARKEST_YELLOW_BG="${BACKLASH_E}[48;2;160;107;31m"
DARK_YELLOW_FG="${BACKLASH_E}[38;2;230;188;13m"
DARK_YELLOW_BG="${BACKLASH_E}[48;2;230;188;13m"
LIGHT_YELLOW_FG="${BACKLASH_E}[38;2;237;243;123m"

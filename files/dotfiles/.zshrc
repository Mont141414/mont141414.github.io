export PS1="${BOLD}${DARK_BLUE_BG}${LIGHTEST_YELLOW_FG} %D ${DARK_YELLOW_BG}${DARK_BLUE_FG}🭬 %T ${LIGHT_YELLOW_BG}${DARK_YELLOW_FG}🭬${DARK_BLUE_FG} %~ ${ERASE}${LIGHT_YELLOW_FG}🭬${ERASE} "
